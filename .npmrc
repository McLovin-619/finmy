auto-install-peers=true
strict-peer-dependencies=false
minimum-release-age=10080

# Hoist these packages to the workspace root node_modules so Metro can resolve
# them when bundling from within react-native's pnpm virtual-store path.
public-hoist-pattern[]=react-native-css-interop
public-hoist-pattern[]=react-native
public-hoist-pattern[]=react
public-hoist-pattern[]=expo
public-hoist-pattern[]=expo-router
public-hoist-pattern[]=expo-*
