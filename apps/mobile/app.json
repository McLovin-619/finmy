{
  "expo": {
    "name": "finmy",
    "slug": "finmy",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "finmy",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.finmy.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#7C3AED"
      },
      "package": "com.finmy.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "@sentry/react-native/expo",
        {
          "organization": "finmy",
          "project": "finmy-mobile"
        }
      ],
      [
        "expo-font",
        {
          "fonts": []
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow finmy to use Face ID to sign you in."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
