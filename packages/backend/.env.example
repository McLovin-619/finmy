# Neon pooled connection string — used by the Hono server at runtime
# Found in Neon dashboard → your project → Connection Details → "Pooled connection"
DATABASE_URL="postgresql://user:password@ep-xxx.pooler.neon.tech/neondb?sslmode=require"

# Neon direct (unpooled) connection string — used only by drizzle-kit for migrations
# Found in Neon dashboard → your project → Connection Details → "Direct connection"
DIRECT_DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"
